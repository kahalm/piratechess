<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="piratechess_maui.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <HorizontalStackLayout Spacing="10">
                <Label Text="Use Bearer Token" VerticalOptions="Center"/>
                <Switch x:Name="SwitchUseBearer" Toggled="OnSwitchUseBearerToggled"/>
            </HorizontalStackLayout>

            <Entry x:Name="EntryBearer"
                   Placeholder="Enter JWT bearer token"
                   IsVisible="False"/>

            <Entry x:Name="EntryEmail"
                   Placeholder="Enter email"/>

            <Entry x:Name="EntryPassword"
                   Placeholder="Enter password"
                   IsPassword="True"/>
            <Label x:Name="LabelChapterCounter"/>
            <Label x:Name="LabelLineCounter"/>
            <Button
                x:Name="ButtonLogin"
                Text="Login" 
                SemanticProperties.Hint="Login"
                HorizontalOptions="Fill" 
                Clicked="OnButtonLoginClicked" />
            <Button
                x:Name="ButtonLoadChapter"
                Text="Load Chapters" 
                SemanticProperties.Hint="Loads all chapters"
                HorizontalOptions="Fill" 
                Clicked="OnButtonLoadChapterClicked" />

            <Picker x:Name="myPicker"
                ItemDisplayBinding="{Binding Value}" />

            <HorizontalStackLayout Spacing="10">
                <CheckBox x:Name="CheckBoxAddMoveEmptyChapters"/>
                <Label Text="Add move to empty chapters" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Label Text="Training move options:" FontAttributes="Bold"/>
            <VerticalStackLayout Spacing="5">
                <RadioButton x:Name="RadioFirstKeyMove"
                             Content="First key move as training move"
                             GroupName="TrainingMode"
                             IsChecked="True"/>
                <RadioButton x:Name="RadioAllKeyMoves"
                             Content="All key moves as training moves"
                             GroupName="TrainingMode"/>
                <RadioButton x:Name="RadioNoTrainingMove"
                             Content="No training move"
                             GroupName="TrainingMode"/>
            </VerticalStackLayout>

            <Button
                x:Name="FirstTenLines"
                Text="First 10 lines"
                SemanticProperties.Hint="Generates the first 10 lines of a given course"
                HorizontalOptions="Fill" 
                Clicked="OnButtonFirstTenLinesClicked" />
            <Button
                x:Name="GenerateCourse"
                Text="Generate whole course" 
                SemanticProperties.Hint="Generates the a given course"
                HorizontalOptions="Fill" 
                Clicked="OnButtonGenerateCourseClicked" />

            <Editor x:Name="EditorPgn"
                Placeholder="Here will be the PGN of your Course"
                HeightRequest="400" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
